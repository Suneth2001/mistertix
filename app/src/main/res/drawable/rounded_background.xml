<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- State when pressed -->
    <item android:state_pressed="true">
        <shape xmlns:android="http://schemas.android.com/apk/res/android">
            <solid android:color="@color/teal_700"/> <!-- Darker color for pressed state -->
            <corners android:radius="16dp"/> <!-- Rounded corners -->
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape xmlns:android="http://schemas.android.com/apk/res/android">
            <solid android:color="@color/white"/> <!-- Background color for normal state -->
            <corners android:radius="10dp"/> <!-- Rounded corners -->
        </shape>
    </item>

</selector>
