<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#E7DBDB"/> <!-- Darker color when pressed -->
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#F4D4D4"/>
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3C3C3C"/> <!-- Normal color -->
            <corners android:radius="8dp"/>
            <stroke android:width="1dp" android:color="#928C8C"/>
        </shape>
    </item>

</selector>
