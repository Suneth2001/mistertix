<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#333333"/> <!-- Darker color when pressed -->
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="@color/mainDark"/>
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mainDark"/> <!-- Normal color -->
            <corners android:radius="8dp"/>
            <stroke android:width="1dp" android:color="@color/theme_color"/>
        </shape>
    </item>

</selector>
