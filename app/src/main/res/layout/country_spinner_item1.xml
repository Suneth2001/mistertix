<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/country_Linear_Layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mainDark1"
    android:orientation="horizontal"
    android:padding="6dp">

    <ImageView
        android:id="@+id/country_imageView"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_horizontal"
        android:layout_weight="1"
        app:srcCompat="@drawable/srilanka" />

    <TextView
        android:id="@+id/spinner_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|left"
        android:layout_weight="2"
        android:text="Sri Lanka"
        android:textColor="@color/other_text"
        android:textSize="18sp" />

</LinearLayout>